# Copy to .env.local

# Website runs on http://localhost:3001 (see package.json start/dev scripts)
# ERP runs on http://localhost:3000

# RGS ONE ERP public content API (production)
NEXT_PUBLIC_CMS_URL="https://one.rgs.co.id/api/website/content"

# Local development (ERP on port 3000)
# NEXT_PUBLIC_CMS_URL="http://localhost:3000/api/website/content"

# Optional — only if WEBSITE_CMS_API_KEY is set on the ERP
# CMS_API_KEY="your-secret-key"

# RGS ONE client & staff login portal
NEXT_PUBLIC_PORTAL_URL="https://one.rgs.co.id/login"

# Local development
# NEXT_PUBLIC_PORTAL_URL="http://localhost:3000/login"

# SMTP — required for /api/contact (contact form)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="noreply@rgs.co.id"
SMTP_PASS="your-smtp-password"
# Where inquiry emails are delivered (defaults to SMTP_USER if unset)
CONTACT_TO="contact@rgs.co.id"
